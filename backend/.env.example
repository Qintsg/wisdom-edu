# =============================================================================
# 知识图谱驱动的个性化自适应学习系统 后端环境变量示例
# backend/wisdom_edu_api/settings.py 默认从 backend/.env 读取配置
# =============================================================================

# -----------------------------------------------------------------------------
# Django基础配置
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=edu.qintsg.xyz,106.14.209.7,127.0.0.1,localhost
USE_X_FORWARDED_HOST=True
CSRF_TRUSTED_ORIGINS=https://edu.qintsg.xyz,http://edu.qintsg.xyz

# -----------------------------------------------------------------------------
# PostgreSQL数据库配置
# -----------------------------------------------------------------------------
DB_NAME=wisdom_edu
DB_USER=wisdom
DB_PASSWORD=wisdom123
DB_HOST=127.0.0.1
DB_PORT=5432

# -----------------------------------------------------------------------------
# Neo4j图数据库配置（可选，用于知识图谱存储）
# 如果不配置Neo4j，系统会自动回退到PostgreSQL进行图查询
# -----------------------------------------------------------------------------
NEO4J_BOLT_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# GraphRAG 混合检索配置
# - hash：默认离线向量器，无需下载模型，适合测试与演示
# - sentence_transformer：本地语义向量器，推荐正式环境启用
# -----------------------------------------------------------------------------
GRAPHRAG_EMBEDDER_PROVIDER=hash
GRAPHRAG_SENTENCE_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
GRAPHRAG_VECTOR_DIMENSION=256
GRAPHRAG_QDRANT_PATH=runtime_logs/rag/qdrant

# -----------------------------------------------------------------------------
# 学习资源 MCP 配置（自研内部资源 MCP + Exa + Firecrawl）
# -----------------------------------------------------------------------------
RESOURCE_MCP_ENABLED=True
RESOURCE_MCP_EXA_ENABLED=True
RESOURCE_MCP_FIRECRAWL_ENABLED=True
RESOURCE_MCP_TIMEOUT_SECONDS=12
RESOURCE_MCP_FIRECRAWL_LIMIT=2

# Exa 语义搜索：用于外部学习资源召回
EXA_API_KEY=
EXA_SEARCH_URL=https://api.exa.ai/search
EXA_SEARCH_TYPE=neural
EXA_MAX_RESULTS=8

# Firecrawl：用于抓取 Exa 命中页面的正文摘要
FIRECRAWL_API_KEY=
FIRECRAWL_SCRAPE_URL=https://api.firecrawl.dev/v1/scrape
FIRECRAWL_TIMEOUT_MILLISECONDS=15000

# -----------------------------------------------------------------------------
# CORS跨域配置
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://edu.qintsg.xyz,http://edu.qintsg.xyz,http://127.0.0.1:3000,http://localhost:3000

# -----------------------------------------------------------------------------
# 大模型配置（AI功能）
# 支持：通义千问(qwen)、DeepSeek、豆包(ModelArk)、智谱(GLM)、Kimi(Moonshot)、自定义兼容网关
# 当前默认统一走 OpenAI 兼容接口；如接入自定义服务，请同时配置 LLM_API_FORMAT / LLM_BASE_URL / LLM_API_KEY
# -----------------------------------------------------------------------------

# 默认提供方（可选值：qwen, deepseek, doubao, zhipu, kimi, custom）
LLM_PROVIDER=deepseek

# 默认使用的模型（示例：deepseek-v4-pro, deepseek-chat, qwen3.6-plus, glm-5, kimi-k2.5）
LLM_MODEL=deepseek-v4-pro

# 接口格式（当前支持：openai-compatible）
LLM_API_FORMAT=openai-compatible

# 默认关闭推理/思考模式；兼容网关需要特殊参数时可调整 LLM_EXTRA_BODY_JSON。
LLM_REASONING_ENABLED=false
LLM_REASONING_EFFORT=
LLM_EXTRA_BODY_JSON={"enable_thinking":false}

# 统一兼容网关 API Key（可选；若为空则按提供方专用 Key 回退）
LLM_API_KEY=

# 统一兼容网关基础URL（可选；若为空则按提供方默认/专用地址回退）
LLM_BASE_URL=

# LLM 请求代理（可选）
# 如果外部模型接口需要走代理，可在此配置；HTTPS 模型网关会优先使用 HTTPS_PROXY / LLM_HTTPS_PROXY。
HTTP_PROXY=
HTTPS_PROXY=
LLM_HTTP_PROXY=
LLM_HTTPS_PROXY=

# 通义千问API密钥（可选，阿里云DashScope）
# 获取地址：https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=

# 通义千问兼容接口地址（默认可留空）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek API密钥
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-key

# DeepSeek 兼容接口地址（默认可留空）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包 / BytePlus ModelArk API密钥（兼容 OpenAI SDK）
# 获取地址：https://docs.byteplus.com/en/docs/ModelArk/1330626
ARK_API_KEY=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# 智谱 / GLM API密钥（兼容 OpenAI SDK）
# 获取地址：https://docs.bigmodel.cn/cn/guide/develop/openai/introduction
ZAI_API_KEY=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Kimi / Moonshot API密钥（兼容 OpenAI SDK）
# 获取地址：https://platform.kimi.ai/docs/api/chat
MOONSHOT_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# 自定义兼容服务（例如企业私有网关）
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=

# -----------------------------------------------------------------------------
# 知识追踪模型配置
# 使用 DKT (Deep Knowledge Tracing) 深度学习模型
# 模型架构: RNN(tanh) → Linear → Sigmoid
# DKT 模型代码位于 /models/DKT/ 目录
# MEFKT 模型代码位于 /models/MEFKT/ 目录
# 训练工具: python tools.py（交互菜单或 train-dkt / train-mefkt 子命令）
# -----------------------------------------------------------------------------

# 预测模式（可选值：single, fusion, ensemble）
# - single: 单模型模式
# - fusion: 融合模式（默认，DKT + MEFKT）
# - ensemble: 集成模式
KT_PREDICTION_MODE=fusion

# 启用的模型列表（逗号分隔）
KT_ENABLED_MODELS=dkt,mefkt

# 融合权重（JSON 格式）
KT_FUSION_WEIGHTS='{"dkt":0.5,"mefkt":0.5}'

# DKT 模型权重文件路径（可选，留空则自动查找 models/DKT/dkt_model.pt）
KT_DKT_MODEL_PATH=models/DKT/dkt_model.pt
KT_DKT_META_PATH=models/DKT/dkt_model.meta.json

# MEFKT 模型权重文件路径（可选，留空则自动查找 models/MEFKT/mefkt_model.pt）
KT_MEFKT_MODEL_PATH=models/MEFKT/mefkt_model.pt
KT_MEFKT_META_PATH=models/MEFKT/mefkt_model.meta.json

# DKT 知识点数量（可选，留空则自动从数据库获取）
KT_DKT_NUM_QUESTIONS=

# DKT 隐藏层维度（默认 200，与训练时一致）
KT_DKT_HIDDEN_DIM=200

# 是否使用GPU加速（需要CUDA支持）
KT_USE_GPU=false

# -----------------------------------------------------------------------------
# 课程资源导入配置
# -----------------------------------------------------------------------------
COURSE_RESOURCES_DIR=tools/自适应学习系统-课程资源

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 操作日志保存目录（默认为项目根目录下的logs/operations/）
LOG_DIR=logs/operations

# 是否开启数据库查询日志（调试用，默认关闭）
DEBUG_LOG_DB_QUERIES=False
