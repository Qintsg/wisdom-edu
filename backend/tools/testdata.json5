            "questions": [
                {"content": "以下哪类图表更适合展示时间趋势？", "point_keys": ["viz_chart"], "options": [{"label": "A", "content": "折线图"}, {"label": "B", "content": "饼图"}, {"label": "C", "content": "词云"}, {"label": "D", "content": "矩阵图"}], "answer": {"answer": "A"}, "analysis": "折线图适合表示随时间变化的趋势。"}
