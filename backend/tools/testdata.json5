    // ============================================
    // 知识点、题库、资源等课程数据
    // create_test_data 会根据下列最小种子数据生成多课程基础闭环
    // ============================================
    "course_seed_content": {
        "大数据技术与应用": {
            "knowledge_points": [
                {"key": "bd_intro", "name": "大数据概述", "chapter": "第1章", "description": "理解大数据基本概念与应用场景"},
                {"key": "bd_hadoop", "name": "Hadoop 生态", "chapter": "第2章", "description": "理解 HDFS 与 MapReduce 的定位"},
                {"key": "bd_spark", "name": "Spark 基础", "chapter": "第3章", "description": "掌握 Spark 核心组件与计算模型"}
            ],
            "relations": [
                {"pre": "bd_intro", "post": "bd_hadoop"},
                {"pre": "bd_hadoop", "post": "bd_spark"}
            ],
            "resources": [
                {"title": "大数据课程导读", "type": "document", "point_keys": ["bd_intro"], "chapter_number": "1.1", "description": "课程整体导读资料"},
                {"title": "Hadoop 架构概览", "type": "document", "point_keys": ["bd_hadoop"], "chapter_number": "2.1", "description": "Hadoop 架构与组件说明"},
                {"title": "Spark 入门视频", "type": "video", "point_keys": ["bd_spark"], "chapter_number": "3.1", "description": "Spark 基础快速入门视频"}
            ],
            "questions": [
                {"content": "以下哪一项最符合大数据的特征？", "point_keys": ["bd_intro"], "options": [{"label": "A", "content": "容量大"}, {"label": "B", "content": "速度快"}, {"label": "C", "content": "多样性"}, {"label": "D", "content": "以上都是"}], "answer": {"answer": "D"}, "analysis": "大数据通常强调 4V 等特征。"},
                {"content": "HDFS 主要解决的是哪类问题？", "point_keys": ["bd_hadoop"], "options": [{"label": "A", "content": "分布式存储"}, {"label": "B", "content": "图像识别"}, {"label": "C", "content": "模型训练"}, {"label": "D", "content": "事务处理"}], "answer": {"answer": "A"}, "analysis": "HDFS 是 Hadoop 的分布式文件系统。"},
                {"content": "Spark 相比传统 MapReduce 更强调内存计算。", "question_type": "true_false", "point_keys": ["bd_spark"], "options": [], "answer": {"answer": true}, "analysis": "Spark 的核心优势之一是以内存计算提升迭代效率。"}
            ]
        },
        "机器学习导论": {
            "knowledge_points": [
                {"key": "ml_intro", "name": "机器学习概述", "chapter": "第1章", "description": "理解机器学习基本任务"},
                {"key": "ml_supervised", "name": "监督学习", "chapter": "第2章", "description": "理解分类与回归问题"},
                {"key": "ml_eval", "name": "模型评估", "chapter": "第3章", "description": "掌握准确率与召回率等指标"}
            ],
            "relations": [
                {"pre": "ml_intro", "post": "ml_supervised"},
                {"pre": "ml_supervised", "post": "ml_eval"}
            ],
            "resources": [
                {"title": "机器学习课程导论", "type": "document", "point_keys": ["ml_intro"], "chapter_number": "1.1", "description": "机器学习问题分类导读"},
                {"title": "监督学习案例解析", "type": "document", "point_keys": ["ml_supervised"], "chapter_number": "2.1", "description": "监督学习基础案例"},
                {"title": "模型评估指标说明", "type": "link", "point_keys": ["ml_eval"], "chapter_number": "3.1", "description": "模型评估相关外部资料"}
            ],
            "questions": [
                {"content": "监督学习通常需要什么样的数据？", "point_keys": ["ml_supervised"], "options": [{"label": "A", "content": "带标签数据"}, {"label": "B", "content": "无标签数据"}, {"label": "C", "content": "仅图像数据"}, {"label": "D", "content": "仅文本数据"}], "answer": {"answer": "A"}, "analysis": "监督学习依赖带标签样本。"},
                {"content": "准确率和召回率都属于模型评估指标。", "question_type": "true_false", "point_keys": ["ml_eval"], "options": [], "answer": {"answer": true}, "analysis": "它们都是分类任务中的常用评估指标。"}
            ]
        },
        "数据可视化基础": {
            "knowledge_points": [
