                {"title": "基础图表实战", "type": "video", "point_keys": ["viz_chart"], "chapter_number": "2.1", "description": "常用图表制作示例"},
                {"title": "数据叙事案例", "type": "document", "point_keys": ["viz_story"], "chapter_number": "3.1", "description": "典型数据叙事结构案例"}
