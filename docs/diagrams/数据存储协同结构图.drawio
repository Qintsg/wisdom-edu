        <!-- 应用层 -> 模型文件 -->
        <mxCell id="c4" value="&lt;font style=&quot;font-size:9px&quot;&gt;PyTorch Load&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="app_layer" target="model_zone">
