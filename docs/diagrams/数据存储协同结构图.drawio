          <mxGeometry x="20" y="200" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="neo5" value="&lt;b&gt;[:INCLUDES]&lt;/b&gt;&lt;br&gt;包含关系" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;" vertex="1" parent="neo_zone">
          <mxGeometry x="140" y="200" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="neo6" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Cypher&lt;/b&gt; 查询&lt;br&gt;路径遍历 / BFS&lt;br&gt;传递闭包 / 图推理&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#82b366;" vertex="1" parent="neo_zone">
