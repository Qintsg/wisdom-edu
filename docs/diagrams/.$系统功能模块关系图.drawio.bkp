        </mxCell>

        <!-- 学习路径模块 (左下) -->
        <mxCell id="m_learning" value="&lt;b&gt;学习路径&lt;/b&gt;&lt;br&gt;(learning)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;自适应路径/节点&lt;br&gt;任务进度/动态调整&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="400" width="200" height="80" as="geometry" />
