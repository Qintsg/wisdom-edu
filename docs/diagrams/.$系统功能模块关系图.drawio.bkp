<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="系统功能模块关系图">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size:18px&quot;&gt;系统功能模块关系图&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="370" y="10" width="210" height="36" as="geometry" />
        </mxCell>

        <!-- ========== 核心模块节点 ========== -->
        <!-- 用户模块 (中上) -->
        <mxCell id="m_users" value="&lt;b&gt;用户管理&lt;/b&gt;&lt;br&gt;(users)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;注册/登录/角色/激活码&lt;br&gt;班级邀请/学习偏好&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="70" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- 课程模块 (左上) -->
        <mxCell id="m_courses" value="&lt;b&gt;课程管理&lt;/b&gt;&lt;br&gt;(courses)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;课程/班级/选课/公告&lt;br&gt;课程发布/班级课程关联&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- 知识模块 (中) -->
